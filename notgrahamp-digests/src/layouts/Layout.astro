---
interface Props {
  title?: string;
}

const { title = '@notgrahamp Daily Digests' } = Astro.props;
const path = Astro.url.pathname;
const isAdminPath = path.startsWith('/admin');
const showAdminLink = !isAdminPath;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css">
  </head>
  <body class="bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
      <header class="mb-12 text-center">
        <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">
          @notgrahamp Daily Digests
        </h1>
        <p class="text-slate-600 dark:text-slate-400">
          Daily insights from Twitter
        </p>
        {showAdminLink && (
          <a 
            href="/admin" 
            class="inline-block mt-4 text-sm bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-lg transition-colors"
          >
            Admin Panel
          </a>
        )}
      </header>
      <main class="space-y-8">
        <slot />
      </main>
      <footer class="mt-16 text-center text-sm text-slate-500 dark:text-slate-500">
        <p>Auto-generated by tweet monitoring system</p>
      </footer>
    </div>
  </body>
</html>
