---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

// Read all markdown files from the digest directory
const digestDir = './data/notgrahamp-daily-digest';
const digests: Array<{
  filename: string;
  date: string;
  content: string;
}> = [];

try {
  const files = fs.readdirSync(digestDir)
    .filter(file => file.endsWith('.md'))
    .sort()
    .reverse(); // Newest first

  for (const file of files) {
    const filePath = path.join(digestDir, file);
    const content = fs.readFileSync(filePath, 'utf-8');
    const dateMatch = file.match(/(\d{4}-\d{2}-\d{2})/);
    const date = dateMatch ? dateMatch[1] : file;
    
    digests.push({
      filename: file,
      date,
      content
    });
  }
} catch (error) {
  console.error('Error reading digest files:', error);
}

// Helper function to parse markdown content
function parseMarkdown(content: string): string {
  const lines = content.split('\n');
  let html = '';
  let inList = false;
  let inCodeBlock = false;

  for (const line of lines) {
    // Skip the first few header lines
    if (line.startsWith('# Daily Tweet Digest') || 
        line.startsWith('**Date:**') ||
        line.startsWith('**Generated:**')) {
      continue;
    }

    // Handle code blocks
    if (line.startsWith('```')) {
      inCodeBlock = !inCodeBlock;
      continue;
    }
    if (inCodeBlock) {
      html += line + '\n';
      continue;
    }

    // Handle headers
    if (line.startsWith('## ')) {
      if (inList) {
        html += '</ul>\n';
        inList = false;
      }
      html += `<h3 class="text-xl font-semibold text-slate-800 dark:text-slate-200 mt-6 mb-3">${line.slice(3)}</h3>\n`;
      continue;
    }

    // Handle list items
    if (line.startsWith('- ')) {
      if (!inList) {
        html += '<ul class="list-disc list-inside space-y-2 mt-3 ml-4">\n';
        inList = true;
      }
      const item = line.slice(2);
      html += `<li class="text-slate-700 dark:text-slate-300">${item}</li>\n`;
      continue;
    }

    // Handle details/summary sections
    if (line.startsWith('*Template section')) {
      if (inList) {
        html += '</ul>\n';
        inList = false;
      }
      html += `<p class="text-slate-500 dark:text-slate-500 italic mt-2">${line.slice(1)}</p>\n`;
      continue;
    }

    // Handle horizontal rules
    if (line.startsWith('---')) {
      if (inList) {
        html += '</ul>\n';
        inList = false;
      }
      html += '<hr class="my-6 border-slate-200 dark:border-slate-700">\n';
      continue;
    }

    // Handle paragraph text
    if (line.trim() && !line.startsWith('*')) {
      if (inList) {
        html += '</ul>\n';
        inList = false;
      }
      html += `<p class="text-slate-700 dark:text-slate-300 mt-3">${line}</p>\n`;
    }
  }

  if (inList) {
    html += '</ul>\n';
  }

  return html;
}
---

<Layout title="@notgrahamp Daily Digests">
  {digests.length === 0 ? (
    <div class="text-center py-12">
      <p class="text-slate-600 dark:text-slate-400 text-lg">
        No digests available yet. Check back soon!
      </p>
    </div>
  ) : (
    <div class="space-y-8">
      {digests.map(digest => (
        <article class="bg-white dark:bg-slate-800 rounded-lg shadow-md p-6 sm:p-8">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">
              Daily Digest
            </h2>
            <time 
              datetime={digest.date}
              class="text-sm font-medium text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-700 px-3 py-1 rounded-full"
            >
              {new Date(digest.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
          </div>
          
          <div set:html={parseMarkdown(digest.content)} />
        </article>
      ))}
    </div>
  )}
</Layout>
