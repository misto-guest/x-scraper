---
export const prerender = false;

import { getReview, updateReview } from '../../../lib/admin-utils';

// Check authentication
const authCookie = Astro.cookies.get('admin_auth');
const isAuthenticated = authCookie?.value === 'true';

if (!isAuthenticated) {
  return Astro.redirect('/admin/login');
}

const id = Astro.url.searchParams.get('id');
if (!id) {
  return Astro.redirect('/admin/reviews');
}

const review = getReview(id);
if (!review) {
  return Astro.redirect('/admin/reviews');
}

// Handle update
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const notes = formData.get('notes') as string;
  const actionItemsText = formData.get('actionItems') as string;

  const actionItems = actionItemsText
    .split('\n')
    .filter(line => line.trim())
    .map(line => {
      const trimmed = line.trim();
      return {
        text: trimmed.replace(/^\[x\]|\[ \]/, '').trim(),
        completed: trimmed.startsWith('[x]')
      };
    });

  updateReview(id, {
    notes,
    actionItems
  });

  return Astro.redirect('/admin/reviews?updated=true');
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Review - Admin Panel</title>
    <link rel="stylesheet" href="/styles/global.css">
  </head>
  <body class="bg-slate-50 dark:bg-slate-900 min-h-screen">
    <div class="max-w-4xl mx-auto p-8">
      <div class="mb-8">
        <a href="/admin/reviews" class="text-blue-600 dark:text-blue-400 hover:underline">
          ← Back to Reviews
        </a>
      </div>

      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-8">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-6">Edit Review</h1>
        
        <form method="POST" class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
              Date
            </label>
            <input
              type="text"
              value={review.date}
              disabled
              class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400"
            />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
              Notes
            </label>
            <textarea
              name="notes"
              rows="6"
              class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
              placeholder="Enter your review notes..."
            >{review.notes}</textarea>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
              Action Items
            </label>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-2">
              Use [x] to mark items as complete, [ ] for incomplete
            </p>
            <textarea
              name="actionItems"
              rows="10"
              class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white font-mono text-sm"
              placeholder="[ ] Action item 1&#10;[x] Completed item&#10;[ ] Another item"
            >{review.actionItems?.map(item => `${item.completed ? '[x]' : '[ ]'} ${item.text}`).join('\n') || ''}</textarea>
          </div>

          <div class="flex justify-between pt-4">
            <a
              href="/admin/reviews"
              class="px-6 py-3 border border-slate-300 dark:border-slate-600 rounded-lg text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700"
            >
              Cancel
            </a>
            <button
              type="submit"
              class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold"
            >
              Save Changes
            </button>
          </div>
        </form>

        <div class="mt-8 pt-6 border-t border-slate-200 dark:border-slate-700">
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Created: {new Date(review.createdAt).toLocaleString()}
          </p>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Last Updated: {new Date(review.updatedAt).toLocaleString()}
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
