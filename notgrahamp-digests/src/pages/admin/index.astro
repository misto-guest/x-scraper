---
export const prerender = false;

import { getAdminData } from '../../lib/admin-utils';

// Check authentication
const authCookie = Astro.cookies.get('admin_auth');
const isAuthenticated = authCookie?.value === 'true';

if (!isAuthenticated) {
  return Astro.redirect('/admin/login');
}

const data = getAdminData();
const reviewCount = data.reviews.length;
const actionItemCount = data.actionItems.length;
const reviewedTweetsCount = Object.values(data.tweets).filter(t => t.status === 'reviewed').length;
const archivedTweetsCount = Object.values(data.tweets).filter(t => t.status === 'archived').length;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel - Dashboard</title>
    <link rel="stylesheet" href="/styles/global.css">
  </head>
  <body class="bg-slate-50 dark:bg-slate-900 min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-white dark:bg-slate-800 shadow-md p-6">
        <div class="mb-8">
          <h1 class="text-xl font-bold text-slate-900 dark:text-white">Admin Panel</h1>
          <p class="text-sm text-slate-500 dark:text-slate-400">notgrahamp digests</p>
        </div>
        
        <nav class="space-y-2">
          <a href="/admin" class="block px-4 py-2 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 font-medium">
            Dashboard
          </a>
          <a href="/admin/reviews" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Reviews
          </a>
          <a href="/admin/tweets" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Tweets
          </a>
          <a href="/admin/action-converter" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Action Converter
          </a>
          <a href="/admin/analyze" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            <span class="mr-2">🔍</span>Tweet Analyzer
          </a>
          <a href="/admin/settings" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            <span class="mr-2">⚙️</span>Settings
          </a>
          <a href="/admin/export" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Export Data
          </a>
          <a href="/admin/logout" class="block px-4 py-2 rounded-lg text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">
            Logout
          </a>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-8">Dashboard</h2>
          
          <!-- Stats cards -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Total Reviews</p>
                  <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">{reviewCount}</p>
                </div>
                <div class="text-4xl">📝</div>
              </div>
            </div>
            
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Action Items</p>
                  <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">{actionItemCount}</p>
                </div>
                <div class="text-4xl">✅</div>
              </div>
            </div>
            
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Reviewed Tweets</p>
                  <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">{reviewedTweetsCount}</p>
                </div>
                <div class="text-4xl">👀</div>
              </div>
            </div>
            
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Archived Tweets</p>
                  <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">{archivedTweetsCount}</p>
                </div>
                <div class="text-4xl">📦</div>
              </div>
            </div>
          </div>

          <!-- Quick actions -->
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">Quick Actions</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <a href="/admin/reviews?action=create" class="block p-4 border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-lg hover:border-blue-500 dark:hover:border-blue-400 transition-colors text-center">
                <span class="text-2xl mb-2 block">➕</span>
                <span class="text-slate-700 dark:text-slate-300 font-medium">Create Review</span>
              </a>
              <a href="/admin/action-converter" class="block p-4 border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-lg hover:border-blue-500 dark:hover:border-blue-400 transition-colors text-center">
                <span class="text-2xl mb-2 block">🤖</span>
                <span class="text-slate-700 dark:text-slate-300 font-medium">Convert Tweet to Action</span>
              </a>
              <a href="/admin/export" class="block p-4 border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-lg hover:border-blue-500 dark:hover:border-blue-400 transition-colors text-center">
                <span class="text-2xl mb-2 block">📤</span>
                <span class="text-slate-700 dark:text-slate-300 font-medium">Export Data</span>
              </a>
            </div>
          </div>

          <!-- Recent activity -->
          <div class="mt-8 bg-white dark:bg-slate-800 rounded-lg shadow p-6">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">System Status</h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Last Updated</span>
                <span class="text-slate-900 dark:text-white font-medium">
                  {data.settings.lastUpdated 
                    ? new Date(data.settings.lastUpdated).toLocaleString() 
                    : 'Never'}
                </span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Data Storage</span>
                <span class="text-slate-900 dark:text-white font-medium">JSON File</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-slate-600 dark:text-slate-400">Authentication</span>
                <span class="text-green-600 dark:text-green-400 font-medium">✓ Active</span>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
