---
export const prerender = false;

import { createActionItem } from '../../lib/admin-utils';

// Check authentication
const authCookie = Astro.cookies.get('admin_auth');
const isAuthenticated = authCookie?.value === 'true';

if (!isAuthenticated) {
  return Astro.redirect('/admin/login');
}

const tweetContent = Astro.url.searchParams.get('content') || '';
const tweetId = Astro.url.searchParams.get('tweetId') || '';

// Handle conversion form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title = formData.get('title') as string;
  const description = formData.get('description') as string;
  const priority = formData.get('priority') as string;
  const category = formData.get('category') as string;
  const estimatedEffort = formData.get('estimatedEffort') as string;
  const dependencies = formData.get('dependencies') as string;
  const sourceTweetId = formData.get('sourceTweetId') as string;
  const sourceTweetContent = formData.get('sourceTweetContent') as string;

  createActionItem({
    title,
    description,
    priority: priority as 'high' | 'medium' | 'low',
    category,
    estimatedEffort: parseInt(estimatedEffort) || 0,
    dependencies: dependencies || '',
    sourceTweetId: sourceTweetId || undefined,
    sourceTweetContent: sourceTweetContent || undefined,
    status: 'pending'
  });

  return Astro.redirect('/admin/action-converter?success=true');
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Action Converter - Admin Panel</title>
    <link rel="stylesheet" href="/styles/global.css">
    <script>
      // Add loading state styles
      addEventListener('load', () => {
        const style = document.createElement('style');
        style.textContent = `
          .loading { opacity: 0.6; pointer-events: none; }
          .spinner { display: inline-block; width: 20px; height: 20px; border: 3px solid rgba(255,255,255,.3); border-radius: 50%; border-top-color: #fff; animation: spin 1s ease-in-out infinite; }
          @keyframes spin { to { transform: rotate(360deg); } }
        `;
        document.head.appendChild(style);
      });
    </script>
  </head>
  <body class="bg-slate-50 dark:bg-slate-900 min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-white dark:bg-slate-800 shadow-md p-6">
        <div class="mb-8">
          <h1 class="text-xl font-bold text-slate-900 dark:text-white">Admin Panel</h1>
          <p class="text-sm text-slate-500 dark:text-slate-400">notgrahamp digests</p>
        </div>
        
        <nav class="space-y-2">
          <a href="/admin" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Dashboard
          </a>
          <a href="/admin/reviews" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Reviews
          </a>
          <a href="/admin/tweets" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Tweets
          </a>
          <a href="/admin/action-converter" class="block px-4 py-2 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 font-medium">
            Action Converter
          </a>
          <a href="/admin/analyze" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            <span class="mr-2">🔍</span>Tweet Analyzer
          </a>
          <a href="/admin/settings" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            <span class="mr-2">⚙️</span>Settings
          </a>
          <a href="/admin/export" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Export Data
          </a>
          <a href="/admin/logout" class="block px-4 py-2 rounded-lg text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">
            Logout
          </a>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Action Item Converter</h2>
          <p class="text-slate-600 dark:text-slate-400 mb-8">
            Convert tweet content into actionable items using AI
          </p>

          <!-- Input section -->
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 mb-8">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">Input</h3>
            
            <div class="mb-4">
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Tweet Content
              </label>
              <textarea
                id="tweetInput"
                rows="6"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
                placeholder="Paste the tweet content here..."
              >{tweetContent}</textarea>
            </div>

            <button
              id="convertBtn"
              onclick="convertToAction()"
              class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors"
            >
              Convert with AI
            </button>
          </div>

          <!-- Result section -->
          <div id="resultSection" class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 hidden">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">Generated Action Item</h3>
            
            <form id="actionForm" method="POST">
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                    Title *
                  </label>
                  <input
                    type="text"
                    id="title"
                    name="title"
                    required
                    class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
                    placeholder="Action item title"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                    Description *
                  </label>
                  <textarea
                    id="description"
                    name="description"
                    rows="4"
                    required
                    class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
                    placeholder="What needs to be done..."
                  ></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                      Priority
                    </label>
                    <select
                      id="priority"
                      name="priority"
                      class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
                    >
                      <option value="high">High</option>
                      <option value="medium" selected>Medium</option>
                      <option value="low">Low</option>
                    </select>
                  </div>

                  <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                      Category
                    </label>
                    <input
                      type="text"
                      id="category"
                      name="category"
                      class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
                      placeholder="e.g., frontend, backend"
                    />
                  </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                      Estimated Effort (hours)
                    </label>
                    <input
                      type="number"
                      id="estimatedEffort"
                      name="estimatedEffort"
                      min="0"
                      step="0.5"
                      class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
                      placeholder="2"
                    />
                  </div>

                  <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                      Dependencies
                    </label>
                    <input
                      type="text"
                      id="dependencies"
                      name="dependencies"
                      class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
                      placeholder="e.g., Design review needed"
                    />
                  </div>
                </div>

                <input type="hidden" name="sourceTweetId" value={tweetId} />
                <input type="hidden" name="sourceTweetContent" id="sourceTweetContent" value={tweetContent} />

                <div class="flex justify-end space-x-3 pt-4">
                  <button
                    type="button"
                    onclick="document.getElementById('resultSection').classList.add('hidden')"
                    class="px-6 py-3 border border-slate-300 dark:border-slate-600 rounded-lg text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700"
                  >
                    Cancel
                  </button>
                  <button
                    type="submit"
                    class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white rounded-lg font-semibold"
                  >
                    Save Action Item
                  </button>
                </div>
              </div>
            </form>
          </div>

          <!-- Recent action items -->
          <div class="mt-8 bg-white dark:bg-slate-800 rounded-lg shadow p-6">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">How It Works</h3>
            <ol class="list-decimal list-inside space-y-2 text-slate-700 dark:text-slate-300">
              <li>Paste tweet content or select from the Tweets page</li>
              <li>Click "Convert with AI" to generate an action item</li>
              <li>Review and edit the generated action item</li>
              <li>Save to your task list</li>
            </ol>
            
            <div class="mt-6 p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg">
              <p class="text-sm text-yellow-800 dark:text-yellow-400">
                <strong>Note:</strong> This uses OpenAI's API. Make sure to set OPENAI_API_KEY in your environment variables.
              </p>
            </div>
          </div>
        </div>
      </main>
    </div>

    <script>
      async function convertToAction() {
        const tweetContent = document.getElementById('tweetInput').value.trim();
        
        if (!tweetContent) {
          alert('Please enter tweet content first');
          return;
        }

        const btn = document.getElementById('convertBtn');
        btn.classList.add('loading');
        btn.innerHTML = '<span class="spinner"></span> Converting...';

        try {
          const response = await fetch('/admin/api/convert', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content: tweetContent })
          });

          if (!response.ok) {
            throw new Error('Conversion failed');
          }

          const data = await response.json();
          
          // Populate form
          document.getElementById('title').value = data.title || '';
          document.getElementById('description').value = data.description || '';
          document.getElementById('priority').value = data.priority || 'medium';
          document.getElementById('category').value = data.category || '';
          document.getElementById('estimatedEffort').value = data.estimatedEffort || '';
          document.getElementById('dependencies').value = data.dependencies || '';
          document.getElementById('sourceTweetContent').value = tweetContent;

          // Show result section
          document.getElementById('resultSection').classList.remove('hidden');
          document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth' });
        } catch (error) {
          alert('Error converting tweet: ' + error.message + '\n\nMake sure OPENAI_API_KEY is set.');
        } finally {
          btn.classList.remove('loading');
          btn.innerHTML = 'Convert with AI';
        }
      }
    </script>
  </body>
</html>
