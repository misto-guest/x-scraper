---
export const prerender = false;

// Check authentication
const authCookie = Astro.cookies.get('admin_auth');
const isAuthenticated = authCookie?.value === 'true';

if (!isAuthenticated) {
  return Astro.redirect('/admin/login');
}

import { getProjects, getOpenClawCategories } from '../../lib/admin-utils';

const projects = getProjects();
const categories = getOpenClawCategories();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Settings - Admin Panel</title>
    <link rel="stylesheet" href="/styles/global.css">
    <script>
      addEventListener('load', () => {
        const style = document.createElement('style');
        style.textContent = `
          .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 16px 24px;
            border-radius: 12px;
            color: white;
            font-weight: 500;
            z-index: 1000;
            animation: slideIn 0.3s ease;
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.2);
          }
          @keyframes slideIn {
            from { transform: translateX(400px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
          }
          .toast.success { background: linear-gradient(135deg, #10b981, #059669); }
          .toast.error { background: linear-gradient(135deg, #ef4444, #dc2626); }
          .relevance-bar {
            height: 8px;
            border-radius: 4px;
            background: #e2e8f0;
            overflow: hidden;
          }
          .relevance-fill {
            height: 100%;
            transition: width 0.3s ease, background 0.3s ease;
          }
          .keyword-tag {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 12px;
            margin: 2px;
          }
        `;
        document.head.appendChild(style);
      });
    </script>
  </head>
  <body class="bg-slate-50 dark:bg-slate-900 min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-white dark:bg-slate-800 shadow-md p-6">
        <div class="mb-8">
          <h1 class="text-xl font-bold text-slate-900 dark:text-white">Admin Panel</h1>
          <p class="text-sm text-slate-500 dark:text-slate-400">notgrahamp digests</p>
        </div>

        <nav class="space-y-2">
          <a href="/admin" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Dashboard
          </a>
          <a href="/admin/reviews" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Reviews
          </a>
          <a href="/admin/tweets" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Tweets
          </a>
          <a href="/admin/analyze" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Tweet Analyzer
          </a>
          <a href="/admin/action-converter" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Action Converter
          </a>
          <a href="/admin/settings" class="block px-4 py-2 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 font-medium">
            <span class="mr-2">⚙️</span>Settings
          </a>
          <a href="/admin/export" class="block px-4 py-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700">
            Export Data
          </a>
          <a href="/admin/logout" class="block px-4 py-2 rounded-lg text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">
            Logout
          </a>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <div class="max-w-5xl mx-auto">
          <div class="mb-8">
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Settings</h2>
            <p class="text-slate-600 dark:text-slate-400">
              Manage projects and categorization rules
            </p>
          </div>

          <!-- Projects Section -->
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 mb-6">
            <div class="flex justify-between items-center mb-4">
              <h3 class="text-xl font-semibold text-slate-900 dark:text-white">Projects</h3>
              <button
                onclick="openProjectModal()"
                class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors"
              >
                + Add Project
              </button>
            </div>

            <div id="projectsList" class="space-y-4">
              <!-- Projects will be rendered here -->
            </div>
          </div>

          <!-- OpenClaw Categories Section -->
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 mb-6">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">OpenClaw Categories</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-4">
              These categories are used for auto-detecting OpenClaw upgrade types from tweets.
            </p>

            <div id="categoriesList" class="space-y-4">
              <!-- Categories will be rendered here -->
            </div>
          </div>

          <!-- Test Keyword Matching -->
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">Test Keyword Matching</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-4">
              Test how well your keywords match sample text.
            </p>

            <div class="mb-4">
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Sample Text
              </label>
              <textarea
                id="testText"
                rows="4"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
                placeholder="Paste sample tweet text here to test keyword matching..."
              ></textarea>
            </div>

            <button
              onclick="testKeywordMatching()"
              class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors"
            >
              Test Matching
            </button>

            <div id="testResults" class="mt-4 hidden">
              <!-- Test results will appear here -->
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Project Modal -->
    <div id="projectModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center">
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-xl p-6 w-full max-w-lg mx-4">
        <h3 id="modalTitle" class="text-xl font-semibold text-slate-900 dark:text-white mb-4">Add Project</h3>

        <form id="projectForm" onsubmit="saveProject(event)">
          <input type="hidden" id="projectId">

          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
              Project Name
            </label>
            <input
              type="text"
              id="projectName"
              required
              class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
              placeholder="e.g., Facebook monetisation programme"
            />
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
              Keywords (comma-separated)
            </label>
            <input
              type="text"
              id="projectKeywords"
              required
              class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
              placeholder="e.g., monetization, reels, facebook, meta"
            />
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
              These keywords will be used to match relevant tweets
            </p>
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
              Relevance Threshold (%)
            </label>
            <input
              type="number"
              id="projectThreshold"
              min="0"
              max="100"
              required
              class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
              placeholder="70"
            />
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
              Minimum relevance score to consider a tweet relevant (0-100)
            </p>
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
              Description
            </label>
            <textarea
              id="projectDescription"
              required
              rows="3"
              class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
              placeholder="What does this project track?"
            ></textarea>
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
              Action Template
            </label>
            <textarea
              id="projectTemplate"
              required
              rows="2"
              class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 bg-white dark:bg-slate-700 text-slate-900 dark:text-white"
              placeholder="Use {tweetUrl} as a placeholder for the tweet URL"
            ></textarea>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
              Use {tweetUrl} as a placeholder. This will be used when creating actions.
            </p>
          </div>

          <div class="flex justify-end space-x-3">
            <button
              type="button"
              onclick="closeProjectModal()"
              class="px-4 py-2 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700"
            >
              Save Project
            </button>
          </div>
        </form>
      </div>
    </div>

    <script>
      let projects = JSON.parse(decodeURIComponent(`${encodeURIComponent(JSON.stringify(Object.values(JSON.parse(`${JSON.stringify({projects: []})}`).projects || {}))}`));
      let categories = [];

      // Load initial data
      document.addEventListener('DOMContentLoaded', () => {
        loadProjects();
        loadCategories();
      });

      async function loadProjects() {
        const response = await fetch('/admin/api/settings/projects');
        const data = await response.json();
        projects = data.projects || [];
        renderProjects();
      }

      async function loadCategories() {
        const response = await fetch('/admin/api/settings/categories');
        const data = await response.json();
        categories = data.categories || [];
        renderCategories();
      }

      function renderProjects() {
        const container = document.getElementById('projectsList');

        if (projects.length === 0) {
          container.innerHTML = '<p class="text-slate-500 dark:text-slate-400">No projects yet. Add one to get started.</p>';
          return;
        }

        container.innerHTML = projects.map(project => `
          <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4">
            <div class="flex justify-between items-start mb-2">
              <div>
                <h4 class="font-semibold text-slate-900 dark:text-white">${project.name}</h4>
                <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">${project.description}</p>
              </div>
              <div class="flex space-x-2">
                <button onclick="editProject('${project.id}')" class="text-blue-600 hover:text-blue-700 text-sm">Edit</button>
                <button onclick="deleteProject('${project.id}')" class="text-red-600 hover:text-red-700 text-sm">Delete</button>
              </div>
            </div>
            <div class="mt-3">
              <div class="flex flex-wrap gap-1 mb-2">
                ${project.keywords.map(kw => `<span class="keyword-tag bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400">${kw}</span>`).join('')}
              </div>
              <div class="flex items-center text-sm text-slate-600 dark:text-slate-400">
                <span class="mr-4">Threshold: <strong>${project.relevanceThreshold}%</strong></span>
              </div>
            </div>
          </div>
        `).join('');
      }

      function renderCategories() {
        const container = document.getElementById('categoriesList');

        container.innerHTML = categories.map(category => `
          <div class="border border-slate-200 dark:border-slate-700 rounded-lg p-4">
            <div class="flex justify-between items-start mb-2">
              <div>
                <h4 class="font-semibold text-slate-900 dark:text-white">${category.name}</h4>
                <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">ID: ${category.id}</p>
              </div>
            </div>
            <div class="mt-3">
              <div class="flex flex-wrap gap-1 mb-2">
                ${category.keywords.map(kw => `<span class="keyword-tag bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400">${kw}</span>`).join('')}
              </div>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Template: ${category.actionTemplate}
              </p>
            </div>
          </div>
        `).join('');
      }

      function openProjectModal(projectId = null) {
        const modal = document.getElementById('projectModal');
        const title = document.getElementById('modalTitle');
        const form = document.getElementById('projectForm');

        form.reset();
        document.getElementById('projectId').value = '';

        if (projectId) {
          const project = projects.find(p => p.id === projectId);
          if (project) {
            title.textContent = 'Edit Project';
            document.getElementById('projectId').value = project.id;
            document.getElementById('projectName').value = project.name;
            document.getElementById('projectKeywords').value = project.keywords.join(', ');
            document.getElementById('projectThreshold').value = project.relevanceThreshold;
            document.getElementById('projectDescription').value = project.description;
            document.getElementById('projectTemplate').value = project.actionTemplate;
          }
        } else {
          title.textContent = 'Add Project';
        }

        modal.classList.remove('hidden');
      }

      function closeProjectModal() {
        document.getElementById('projectModal').classList.add('hidden');
      }

      async function saveProject(event) {
        event.preventDefault();

        const projectId = document.getElementById('projectId').value;
        const projectData = {
          name: document.getElementById('projectName').value,
          keywords: document.getElementById('projectKeywords').value.split(',').map(k => k.trim()).filter(k => k),
          relevanceThreshold: parseInt(document.getElementById('projectThreshold').value),
          description: document.getElementById('projectDescription').value,
          actionTemplate: document.getElementById('projectTemplate').value
        };

        const url = projectId ? `/admin/api/settings/projects/${projectId}` : '/admin/api/settings/projects';
        const method = projectId ? 'PUT' : 'POST';

        try {
          const response = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(projectData)
          });

          if (response.ok) {
            showToast('Project saved successfully!', 'success');
            closeProjectModal();
            loadProjects();
          } else {
            throw new Error('Failed to save project');
          }
        } catch (error) {
          showToast('Error saving project: ' + error.message, 'error');
        }
      }

      function editProject(projectId) {
        openProjectModal(projectId);
      }

      async function deleteProject(projectId) {
        if (!confirm('Are you sure you want to delete this project?')) return;

        try {
          const response = await fetch(`/admin/api/settings/projects/${projectId}`, {
            method: 'DELETE'
          });

          if (response.ok) {
            showToast('Project deleted successfully!', 'success');
            loadProjects();
          } else {
            throw new Error('Failed to delete project');
          }
        } catch (error) {
          showToast('Error deleting project: ' + error.message, 'error');
        }
      }

      async function testKeywordMatching() {
        const text = document.getElementById('testText').value.trim();
        if (!text) {
          showToast('Please enter some text to test', 'error');
          return;
        }

        try {
          const response = await fetch('/admin/api/settings/test-matching', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text })
          });

          const data = await response.json();
          displayTestResults(data);
        } catch (error) {
          showToast('Error testing keywords: ' + error.message, 'error');
        }
      }

      function displayTestResults(data) {
        const container = document.getElementById('testResults');
        container.classList.remove('hidden');

        let html = '<h4 class="font-semibold text-slate-900 dark:text-white mb-3">Matching Results</h4>';

        if (data.projects && data.projects.length > 0) {
          html += '<div class="mb-4"><h5 class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Projects</h5>';
          data.projects.forEach(result => {
            const color = result.score >= 80 ? 'green' : result.score >= 50 ? 'yellow' : 'red';
            html += `
              <div class="mb-2 p-3 bg-slate-50 dark:bg-slate-700 rounded">
                <div class="flex justify-between items-center mb-1">
                  <span class="font-medium">${result.project.name}</span>
                  <span class="text-sm font-bold text-${color}-600">${result.score}%</span>
                </div>
                <div class="relevance-bar">
                  <div class="relevance-fill bg-${color}-500" style="width: ${result.score}%"></div>
                </div>
                ${result.matches ? `<p class="text-xs text-slate-500 mt-1">Matched keywords: ${result.matches.join(', ')}</p>` : ''}
              </div>
            `;
          });
          html += '</div>';
        }

        if (data.category) {
          html += '<div class="mb-4"><h5 class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">OpenClaw Category</h5>';
          html += `
            <div class="p-3 bg-slate-50 dark:bg-slate-700 rounded">
              <div class="flex justify-between items-center mb-1">
                <span class="font-medium">${data.category.name}</span>
                <span class="text-sm font-bold text-green-600">${data.category.score}%</span>
              </div>
              <div class="relevance-bar">
                <div class="relevance-fill bg-green-500" style="width: ${data.category.score}%"></div>
              </div>
              ${data.category.matches ? `<p class="text-xs text-slate-500 mt-1">Matched keywords: ${data.category.matches.join(', ')}</p>` : ''}
            </div>
          `;
          html += '</div>';
        }

        if ((!data.projects || data.projects.length === 0) && !data.category) {
          html += '<p class="text-slate-500 dark:text-slate-400">No matches found. Try adjusting your keywords or test text.</p>';
        }

        container.innerHTML = html;
      }

      function showToast(message, type = 'success') {
        const toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.textContent = message;
        document.body.appendChild(toast);

        setTimeout(() => {
          toast.style.animation = 'slideIn 0.3s ease reverse';
          setTimeout(() => toast.remove(), 300);
        }, 3000);
      }
    </script>
  </body>
</html>
