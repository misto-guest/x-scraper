# Facebook Monetiser - Environment Variables

# z.ai (Runware) API - REQUIRED for AI content generation
RUNWARE_API_KEY=35669f5402e94868aabffee742ae2272.twAEmwMX0Jhd2THG

# Firecrawl API - REQUIRED for competitor scraping
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Facebook Graph API - REQUIRED for posting and monitoring
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_token_here
FACEBOOK_PAGE_ID=your_page_id_here

# Database (SQLite)
DATABASE_PATH=./database/facebook-monetiser.db

# Server
PORT=3000
NODE_ENV=production

# CORS (if frontend is on different domain)
FRONTEND_URL=https://facebook-monetiser.fly.dev
