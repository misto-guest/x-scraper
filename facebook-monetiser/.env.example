# Environment Variables for Facebook Monetiser

# Node Environment
NODE_ENV=production

# Server Port
PORT=3000

# Database Path (for Railway, use persistent volume)
DATABASE_PATH=/data/facebook-monetiser.db

# Optional: Add your Facebook API credentials here when configured
# FACEBOOK_APP_ID=your_app_id
# FACEBOOK_APP_SECRET=your_app_secret
# FACEBOOK_PAGE_ACCESS_TOKEN=your_page_token

# Optional: Add OpenAI API key for AI content generation
# OPENAI_API_KEY=your_openai_api_key
