---
const currentYear = new Date().getFullYear();
---

<footer class="border-t bg-background">
  <div class="container flex flex-col items-center justify-between gap-4 py-8 md:h-16 md:flex-row md:py-0">
    <div class="flex flex-col items-center gap-4 px-8 md:flex-row md:gap-2 md:px-0">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
      </svg>
      <p class="text-center text-sm leading-loose text-muted-foreground md:text-left">
        Built with <span class="text-red-500">♥</span> for modern link management.
      </p>
    </div>
    <div class="flex items-center space-x-4 text-sm text-muted-foreground">
      <a href="/docs" class="hover:text-foreground transition-colors">Documentation</a>
      <a href="/privacy" class="hover:text-foreground transition-colors">Privacy</a>
      <a href="/terms" class="hover:text-foreground transition-colors">Terms</a>
      <span>© {currentYear} Supalinks</span>
    </div>
  </div>
</footer>
