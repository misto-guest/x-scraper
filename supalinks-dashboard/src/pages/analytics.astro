---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Analytics - Supalinks 2.0">
  <div class="container py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight">Analytics</h1>
      <p class="text-muted-foreground">
        Track link performance and user engagement
      </p>
    </div>

    <!-- Stats Overview -->
    <div class="mb-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-muted-foreground">Total Clicks</p>
            <h3 class="text-2xl font-bold">156.2K</h3>
            <p class="mt-1 text-xs text-green-600">↑ 23.1% from last month</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
            </svg>
          </div>
        </div>
      </div>

      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-muted-foreground">Unique Clicks</p>
            <h3 class="text-2xl font-bold">89.5K</h3>
            <p class="mt-1 text-xs text-green-600">↑ 18.7% from last month</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-500/10">
            <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-muted-foreground">Avg. CTR</p>
            <h3 class="text-2xl font-bold">4.2%</h3>
            <p class="mt-1 text-xs text-green-600">↑ 0.8% from last month</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-green-500/10">
            <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
        </div>
      </div>

      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-muted-foreground">Active Links</p>
            <h3 class="text-2xl font-bold">1,892</h3>
            <p class="mt-1 text-xs text-red-600">↓ 2.4% from last month</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-orange-500/10">
            <svg class="h-6 w-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid gap-8 lg:grid-cols-2">
      <!-- Clicks Over Time -->
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold">Clicks Over Time</h2>
        <div class="h-64 flex items-end justify-between gap-1">
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 45%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 65%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 55%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 78%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 92%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 85%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 70%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 88%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 95%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 82%"></div>
          <div class="flex-1 bg-primary/20 hover:bg-primary/40 transition-colors rounded-t" style="height: 75%"></div>
          <div class="flex-1 bg-primary hover:bg-primary/90 transition-colors rounded-t" style="height: 100%"></div>
        </div>
        <div class="mt-4 flex justify-between text-xs text-muted-foreground">
          <span>Jan 1</span>
          <span>Jan 5</span>
          <span>Jan 10</span>
          <span>Jan 15</span>
          <span>Jan 20</span>
          <span>Jan 25</span>
        </div>
      </div>

      <!-- Top Performing Links -->
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold">Top Performing Links</h2>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="font-medium">Summer Sale Campaign</span>
                <span class="rounded-full bg-primary/10 px-2 py-0.5 text-xs text-primary">Active</span>
              </div>
              <p class="text-sm text-muted-foreground">supalinks.cc/summer-sale</p>
            </div>
            <div class="text-right">
              <p class="font-medium">12,543</p>
              <p class="text-xs text-muted-foreground">clicks</p>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="font-medium">New Product Launch</span>
                <span class="rounded-full bg-primary/10 px-2 py-0.5 text-xs text-primary">Active</span>
              </div>
              <p class="text-sm text-muted-foreground">supalinks.cc/product-launch</p>
            </div>
            <div class="text-right">
              <p class="font-medium">8,234</p>
              <p class="text-xs text-muted-foreground">clicks</p>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="font-medium">Referral Program</span>
                <span class="rounded-full bg-primary/10 px-2 py-0.5 text-xs text-primary">Active</span>
              </div>
              <p class="text-sm text-muted-foreground">supalinks.cc/referral-program</p>
            </div>
            <div class="text-right">
              <p class="font-medium">5,621</p>
              <p class="text-xs text-muted-foreground">clicks</p>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="font-medium">Webinar Signup</span>
                <span class="rounded-full bg-muted px-2 py-0.5 text-xs text-muted-foreground">Inactive</span>
              </div>
              <p class="text-sm text-muted-foreground">supalinks.cc/webinar-signup</p>
            </div>
            <div class="text-right">
              <p class="font-medium">3,892</p>
              <p class="text-xs text-muted-foreground">clicks</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Geographic Distribution -->
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold">Geographic Distribution</h2>
        <div class="space-y-3">
          <div>
            <div class="mb-1 flex items-center justify-between text-sm">
              <span>🇺🇸 United States</span>
              <span class="font-medium">42.3%</span>
            </div>
            <div class="h-2 rounded-full bg-muted">
              <div class="h-full rounded-full bg-primary" style="width: 42.3%"></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex items-center justify-between text-sm">
              <span>🇬🇧 United Kingdom</span>
              <span class="font-medium">18.7%</span>
            </div>
            <div class="h-2 rounded-full bg-muted">
              <div class="h-full rounded-full bg-primary" style="width: 18.7%"></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex items-center justify-between text-sm">
              <span>🇩🇪 Germany</span>
              <span class="font-medium">12.4%</span>
            </div>
            <div class="h-2 rounded-full bg-muted">
              <div class="h-full rounded-full bg-primary" style="width: 12.4%"></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex items-center justify-between text-sm">
              <span>🇫🇷 France</span>
              <span class="font-medium">9.8%</span>
            </div>
            <div class="h-2 rounded-full bg-muted">
              <div class="h-full rounded-full bg-primary" style="width: 9.8%"></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex items-center justify-between text-sm">
              <span>🇨🇦 Canada</span>
              <span class="font-medium">7.2%</span>
            </div>
            <div class="h-2 rounded-full bg-muted">
              <div class="h-full rounded-full bg-primary" style="width: 7.2%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Device Breakdown -->
      <div class="rounded-xl border bg-card p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold">Device Breakdown</h2>
        <div class="space-y-3">
          <div>
            <div class="mb-1 flex items-center justify-between text-sm">
              <span>📱 Mobile</span>
              <span class="font-medium">58.4%</span>
            </div>
            <div class="h-2 rounded-full bg-muted">
              <div class="h-full rounded-full bg-purple-600" style="width: 58.4%"></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex items-center justify-between text-sm">
              <span>💻 Desktop</span>
              <span class="font-medium">35.2%</span>
            </div>
            <div class="h-2 rounded-full bg-muted">
              <div class="h-full rounded-full bg-blue-600" style="width: 35.2%"></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex items-center justify-between text-sm">
              <span>📟 Tablet</span>
              <span class="font-medium">6.4%</span>
            </div>
            <div class="h-2 rounded-full bg-muted">
              <div class="h-full rounded-full bg-green-600" style="width: 6.4%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
