# ANP Persportaal Credentials
# Get credentials at https://persportaal.anp.nl
ANP_USERNAME=your_username_here
ANP_PASSWORD=your_password_here

# OpenAI API (for AI-powered insights and strategy generation)
# Get API key at https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Ahrefs API (for accurate backlink data)
# Get API key at https://ahrefs.com/api
AHREFS_API_KEY=your_ahrefs_api_key_here

# Optional: Claude API (alternative to OpenAI)
# Get API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
