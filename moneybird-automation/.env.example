# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Moneybird
MONEYBIRD_API_TOKEN=your_moneybird_token_here
MONEYBIRD_ADMINISTRATION_ID=your_administration_id
MONEYBIRD_WEBHOOK_SECRET=your_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Wise (formerly TransferWise)
WISE_API_KEY=your_wise_api_key
WISE_PROFILE_ID=your_wise_profile_id

# Payoneer (if API available)
PAYONEER_PARTNER_ID=your_partner_id
PAYONEER_API_KEY=your_api_key

# Database (Railway provides these)
DATABASE_URL=postgresql://user:password@localhost:5432/moneybird

# Redis (Railway provides these)
REDIS_URL=redis://localhost:6379

# Security
WEBHOOK_SECRET=generate_random_string_here
JWT_SECRET=generate_random_jwt_secret_here
ENCRYPTION_KEY=generate_32_char_encryption_key

# Railway (auto-populated)
RAILWAY_ENVIRONMENT=
RAILWAY_SERVICE_NAME=
